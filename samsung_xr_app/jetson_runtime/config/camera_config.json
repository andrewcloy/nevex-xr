{
  "project_name": "NEVEX XR stereo runtime",
  "default_profile": "quality_1080p30",
  "camera": {
    "left_sensor_id": 0,
    "right_sensor_id": 1,
    "width": 1920,
    "height": 1080,
    "fps": 30,
    "output_width": 3840,
    "output_height": 1080,
    "expected_video_devices": [
      "/dev/video0",
      "/dev/video1"
    ],
    "flip_method": 0,
    "queue_max_size_buffers": 4
  },
  "output": {
    "mode": "fakesink",
    "output_directory": "../artifacts",
    "preview_filename_prefix": "stereo_preview",
    "preview_jpeg_quality": 70,
    "snapshot_filename_prefix": "stereo_snapshot",
    "recording_filename_prefix": "stereo_capture",
    "recording_container": "mkv",
    "test_duration_seconds": 10,
    "record_duration_seconds": 10,
    "sync": false,
    "h264_bitrate": 8000000
  },
  "runtime": {
    "gst_launch_binary": "gst-launch-1.0",
    "gst_inspect_binary": "gst-inspect-1.0",
    "gst_debug": null,
    "shutdown_grace_seconds": 5,
    "preflight_timeout_seconds": 10,
    "run_preflight_on_start": false
  },
  "features": {
    "stereo_display": false,
    "thermal_overlay": false,
    "ai_detection": false,
    "xr_transport": false
  },
  "profiles": {
    "quality_1080p30": {
      "profile_type": "validation",
      "description": "Balanced 1080p30 stereo validation profile for high-detail proof-of-life and artifact capture.",
      "camera": {
        "width": 1920,
        "height": 1080,
        "fps": 30,
        "output_width": 3840,
        "output_height": 1080,
        "queue_max_size_buffers": 4
      },
      "output": {
        "mode": "fakesink",
        "test_duration_seconds": 10,
        "record_duration_seconds": 10,
        "h264_bitrate": 8000000
      }
    },
    "low_latency_720p60": {
      "extends": "quality_1080p30",
      "profile_type": "operational",
      "description": "Lower-latency 720p60 profile for responsive Jetson bring-up and future live preview work.",
      "camera": {
        "width": 1280,
        "height": 720,
        "fps": 60,
        "output_width": 2560,
        "output_height": 720,
        "queue_max_size_buffers": 2
      },
      "output": {
        "mode": "fakesink",
        "test_duration_seconds": 12,
        "record_duration_seconds": 8
      }
    },
    "record_1080p30": {
      "extends": "quality_1080p30",
      "profile_type": "validation",
      "description": "1080p30 recording profile for bounded stereo artifact capture with a higher recording bitrate.",
      "output": {
        "mode": "file",
        "test_duration_seconds": 15,
        "record_duration_seconds": 15,
        "h264_bitrate": 12000000
      }
    },
    "headset_preview_720p60": {
      "extends": "low_latency_720p60",
      "profile_type": "operational",
      "description": "Operational 720p60 preview profile intended to stay close to future headset-oriented low-latency settings.",
      "camera": {
        "queue_max_size_buffers": 1
      },
      "output": {
        "mode": "fakesink",
        "test_duration_seconds": 15,
        "record_duration_seconds": 10,
        "preview_jpeg_quality": 65
      }
    }
  }
}
