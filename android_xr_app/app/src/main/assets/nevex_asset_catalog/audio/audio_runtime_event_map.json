{
  "pack_name": "NEVEX_XR_AudioPack",
  "version": 1,
  "intent": "Runtime event mapping for Android XR integration. Trigger event IDs, not raw filenames.",
  "default_buses": {
    "master": {"description": "final output bus"},
    "critical_alerts": {"description": "highest priority critical fault bus"},
    "alerts": {"description": "urgent warning bus"},
    "detections": {"description": "high-value detection bus"},
    "navigation": {"description": "navigation and route cue bus"},
    "capture_system": {"description": "capture, system, and readiness confirms"},
    "ui": {"description": "lowest-priority interaction bus"},
    "playback": {"description": "review and playback interaction bus"}
  },
  "cooldown_groups": {
    "ui_focus": {"default_ms": 90},
    "ui_confirm": {"default_ms": 120},
    "readiness_state": {"default_ms": 1500},
    "system_link": {"default_ms": 2000},
    "detection_general": {"default_ms": 2200},
    "detection_track": {"default_ms": 1800},
    "detection_prey": {"default_ms": 2400},
    "navigation_general": {"default_ms": 1800},
    "navigation_heading": {"default_ms": 900},
    "capture_events": {"default_ms": 100},
    "playback_ui": {"default_ms": 100},
    "warning_general": {"default_ms": 5000},
    "critical_faults": {"default_ms": 7000}
  },
  "signature_modes": {
    "normal": {
      "description": "default audio behavior"
    },
    "low_signature": {
      "description": "reduced nonessential audio, especially for live-use confirms and detections"
    },
    "silent": {
      "description": "suppresses most lower-priority cues, preserves critical safety behavior"
    }
  },
