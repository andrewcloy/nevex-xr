        "Mode / Readiness"
      ]
    },
    {
      "title": "Operational Modes",
      "items": [
        "Military / Threat",
        "Hunting / Game",
        "Inspection / Search",
        "Navigation / Patrol",
        "Review / Playback"
      ]
    }
  ]
